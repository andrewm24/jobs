# For local dev: copy to server/.env (never commit the real file).
# For Docker: put ANTHROPIC_API_KEY in a .env file at the REPO ROOT instead
# (docker compose reads it automatically).
# Optional if you've run `ant auth login` locally; the SDK also picks up that profile.
ANTHROPIC_API_KEY=sk-ant-...

# Models are also configurable in the app's Settings (Sources tab); env is the
# fallback. Default generation model is claude-opus-4-8, scoring is claude-haiku-4-5.
# CLAUDE_MODEL=claude-opus-4-8
# SCORING_MODEL=claude-haiku-4-5

# Discovery: max postings scored per scan (also in Settings) and auto-rescan
# interval (hours, 0 = manual scans only).
# SCORE_LIMIT=40
# SCAN_INTERVAL_HOURS=6

# PORT=3001
