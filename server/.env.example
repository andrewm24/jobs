# Copy to server/.env — never commit the real file.
# Optional if you've run `ant auth login`; the SDK also picks up that profile.
ANTHROPIC_API_KEY=sk-ant-...

# Override the model if you want (defaults to claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# Discovery: fit-scoring model (cheap tier by default), max postings scored
# per scan, and auto-rescan interval (hours, 0 = manual scans only).
# SCORING_MODEL=claude-haiku-4-5
# SCORE_LIMIT=40
# SCAN_INTERVAL_HOURS=6

# PORT=3001
